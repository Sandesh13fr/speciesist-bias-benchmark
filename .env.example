OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=Speciesist Bias Benchmark

DEFAULT_MODELS=openai/gpt-4o,openai/gpt-4o-mini,anthropic/claude-3-haiku,anthropic/claude-3.5-sonnet,deepseek/deepseek-chat
DEFAULT_TEMPERATURE=0.2
DEFAULT_MAX_TOKENS=350
REQUEST_TIMEOUT_SECONDS=60
MAX_RETRIES=5
RATE_LIMIT_RPM=30

DATABASE_URL=sqlite:///speciesist_bias.db
REPORTS_DIR=reports
TEMPLATES_DIR=templates
LOG_LEVEL=INFO
